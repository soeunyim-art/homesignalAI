# HomeSignal AI 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_TIMEOUT=10  # Supabase 쿼리 타임아웃 (초)

# PostgreSQL 직접 연결 (선택, ingest/마이그레이션용)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# AI API
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_PROVIDER=openai  # openai 또는 anthropic

# 공공데이터 API (데이터 수집용)
PUBLIC_DATA_API_KEY=your_public_data_api_key_here
ECOS_API_KEY=your_ecos_api_key_here

# Redis (캐싱)
REDIS_URL=redis://localhost:6379/0

# 앱 설정
APP_ENV=development  # development, staging, production
DEBUG=true

# CORS 설정 (프로덕션 필수)
# 예: ALLOWED_ORIGINS=https://homesignal-ai-frontend.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=
